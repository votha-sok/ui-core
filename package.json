{
  "name": "company-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve playground",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:libs": "ng build ui-utils && ng build ui-icons && ng build ui-theme && ng build ui-core && ng build ui-layout",
    "dev:libs": "concurrently \"ng build ui-utils --watch\" \"ng build ui-icons --watch\" \"ng build ui-theme --watch\" \"ng build ui-core --watch\" \"ng build ui-layout --watch\"",
    "dev": "npm run build:libs && node scripts/dev.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.2",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
